# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/frota_pro"

# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# JWT (Autenticação)
# ─────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_secreta_forte_aqui
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# E-MAIL (Alertas de vencimento)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM="FrotaPRO <seu@email.com>"

# ─────────────────────────────────────────────
# SINESP / DETRAN (Consulta de multas)
# ─────────────────────────────────────────────
SINESP_API_URL=https://api.sinesp.gov.br
SINESP_API_KEY=sua_chave_aqui

# ─────────────────────────────────────────────
# RASTREAMENTO GPS
# ─────────────────────────────────────────────
GPS_PROVIDER=sascar           # sascar | omnilink | positron | custom
GPS_API_URL=https://api.sascar.com.br
GPS_API_KEY=sua_chave_aqui
GPS_POLL_INTERVAL=30          # segundos entre atualizações
