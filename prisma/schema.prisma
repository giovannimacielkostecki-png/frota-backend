generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       String  @id @default(uuid())
  nome     String
  email    String  @unique
  senha    String
  perfil   String  @default("ADMIN")
  ativo    Boolean @default(true)
  criadoEm DateTime @default(now())
  fretes   Frete[]
}

model Veiculo {
  id        Int      @id @default(autoincrement())
  placa     String   @unique
  modelo    String
  marca     String?
  ano       Int?
  renavam   String?  @unique
  chassi    String?  @unique
  kmAtual   Int      @default(0)
  status    String   @default("ATIVO")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  abastecimentos Abastecimento[]
  pneus          Pneu[]
  documentos     Documento[]
  multas         Multa[]
  custos         Custo[]
  fretes         Frete[]
  rastreamentos  Rastreamento[]
}

model Abastecimento {
  id            Int      @id @default(autoincrement())
  data          DateTime @default(now())
  litros        Float
  valorTotal    Float
  precoPorLitro Float?
  kmAtual       Int
  kmAnterior    Int?
  consumoKmL    Float?
  posto         String?
  tipoCombustivel String?
  veiculoId     Int
  veiculo       Veiculo  @relation(fields: [veiculoId], references: [id])
}

model Pneu {
  id          Int      @id @default(autoincrement())
  posicao     String
  marca       String?
  modelo      String?
  kmInstalado Int      @default(0)
  kmAtual     Int      @default(0)
  kmRodado    Int      @default(0)
  kmLimite    Int      @default(80000)
  status      String   @default("BOM")
  veiculoId   Int
  veiculo     Veiculo  @relation(fields: [veiculoId], references: [id])
  historico   HistoricoPneu[]
  createdAt   DateTime @default(now())
}

model HistoricoPneu {
  id          Int      @id @default(autoincrement())
  posicaoAnt  String
  posicaoNov  String
  kmRodado    Int
  data
